# LevantiLearn Backend Environment Variables
# Copy to .env and fill in your values

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres

# Redis (Upstash or Railway Redis)
REDIS_URL=redis://localhost:6379

# Firebase Service Account
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# TTS Backend: "coqui" (open-source) or "azure" (fallback)
TTS_BACKEND=coqui

# Azure TTS — used by scripts/generate-audio.ts to pre-generate all lesson audio
# Get from: Azure portal → Cognitive Services → Speech → Keys and Endpoint
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_ENDPOINT=https://eastus.tts.speech.microsoft.com
# Voice: ar-PS-AvriNeural (Palestinian, female) — fallback: ar-SY-AmanyNeural (Syrian, female)
# TTS_BACKEND=azure  (set to use Azure for live synthesis; default is OpenAI + edge-tts fallback)

# Unsplash API (CC0 images) — get from unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Whisper model size: tiny | base | small | medium | large
# Recommendation: "small" for dev, "medium" for prod
WHISPER_MODEL=small

# App settings
APP_ENV=development
CORS_ORIGINS=http://localhost:8081,https://levantilearn.vercel.app

# Stripe (payments — optional for MVP)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PREMIUM_PRICE_ID=price_your_price_id
