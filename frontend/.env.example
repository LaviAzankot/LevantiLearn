# LevantiLearn Frontend Environment Variables
# Copy this file to .env and fill in your values

# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these at: supabase.com/dashboard → your project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── Backend API ───────────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:8000

# ── PayPal ────────────────────────────────────────────────────────────────────
# Find at: developer.paypal.com → My Apps & Credentials
EXPO_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id-here
EXPO_PUBLIC_PAYPAL_ENV=sandbox
